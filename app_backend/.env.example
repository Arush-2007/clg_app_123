# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/college_app

# ── Firebase ──────────────────────────────────────────────
FIREBASE_CREDENTIALS_JSON=
FIREBASE_PROJECT_ID=

# ── App behaviour ─────────────────────────────────────────
APP_ENV=production
APP_DEBUG=false
AUTO_CREATE_SCHEMA=false
RATE_LIMIT_PER_MINUTE=60

# ── Metrics ───────────────────────────────────────────────
PROTECT_METRICS=true
METRICS_TOKEN=

# ── Secrets provider (gcp | aws | env) ────────────────────
SECRETS_PROVIDER=env
GCP_PROJECT_ID=          # your GCP project ID e.g. college-app-prod-123456

# ── Storage (gcs | s3 | local) ────────────────────────────
STORAGE_PROVIDER=local
GCS_BUCKET_NAME=
S3_BUCKET_NAME=
AWS_REGION=

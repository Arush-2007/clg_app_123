# Python
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.ruff_cache/
*.egg-info/

# Environment — never bake secrets into image
.env
.env.*

# Dev/test files — not needed in production image
tests/
*.log
debug-*.log

# Local uploads — served from GCS in production
uploads/

# Alembic compiled files
alembic/versions/*.pyc

# Git
.git/
.gitignore

# Docker itself
Dockerfile
.dockerignore

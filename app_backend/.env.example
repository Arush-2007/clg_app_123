# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/college_app

# ── Firebase ──────────────────────────────────────────────
FIREBASE_CREDENTIALS_JSON=
FIREBASE_PROJECT_ID=

# ── App behaviour ─────────────────────────────────────────
APP_ENV=production
APP_DEBUG=false
AUTO_CREATE_SCHEMA=false
# Production: replace with your real Flutter web domain and/or Firebase Hosting URL
# Cloud Run backend URL is NOT needed here — that's your API, not your frontend origin
CORS_ORIGINS=["http://localhost:3000","https://your-app.web.app","https://your-custom-domain.com"]
CORS_ALLOW_ALL_LOCALHOST=false   # true for local dev, false in production
RATE_LIMIT_PER_MINUTE=60

# ── Metrics ───────────────────────────────────────────────
PROTECT_METRICS=true
METRICS_TOKEN=

# ── Secrets provider (gcp | aws | env) ────────────────────
SECRETS_PROVIDER=env
GCP_PROJECT_ID=          # your GCP project ID e.g. college-app-prod-123456

# ── Storage (gcs | s3 | local) ────────────────────────────
STORAGE_PROVIDER=local
GCS_BUCKET_NAME=
S3_BUCKET_NAME=
AWS_REGION=
